{
  "name": "cool-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:local": "dotenv -e .dev.vars -- astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "deploy": "astro build && wrangler pages deploy ./dist/client --project-name=cool-blog --branch=main",
    "deploy:preview": "astro build && wrangler pages deploy ./dist/client --project-name=cool-blog --branch=preview",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "migrate:notion": "tsx scripts/migrate-notion.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.4",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "@fontsource/inter": "^5.0.0",
    "@fontsource/jetbrains-mono": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.0.2",
    "@types/dompurify": "^3.0.5",
    "@upstash/redis": "^1.37.0",
    "astro": "^6.1.1",
    "dompurify": "^3.3.3",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "csv-parse": "^5.5.3",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^17.0.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.7.0",
    "vitest": "^3.0.0"
  }
}
