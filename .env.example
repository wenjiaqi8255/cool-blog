# Cool Blog Environment Variables
# Copy this file to .env.local and fill in values

# Site URL (optional, for meta tags)
PUBLIC_SITE_URL=https://your-site.pages.dev

# GitHub API (for Stats card)
# Unauthenticated API has 60 requests/hour limit
# For production, consider adding a GitHub token for higher limits
# GITHUB_TOKEN=your_github_token_here

# Newsletter (Phase 3)

# Neon Postgres - get from https://neon.tech console
# Format: postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/cool-blog?sslmode=require

# Resend email - get from https://resend.com/api-keys
# Dev: use @resend.dev test domain (no domain verification needed)
# Prod: use your verified domain (e.g., newsletter@yourdomain.com)
RESEND_API_KEY=re_xxxxx

# Optional: Resend sender address (defaults to noreply@resend.dev in dev)
RESEND_FROM_EMAIL=newsletter@yourdomain.com
