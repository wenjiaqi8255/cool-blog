# ┌─────────────────────────────────────────────────────────────────┐
# │ Cool Blog Environment Variables                                 │
# │                                                                 │
# │ Copy this file to .env.local and fill in values                 │
# │                                                                 │
# │ Quick Setup:                                                    │
# │ 1. Create Neon database: https://neon.tech (free tier available)│
# │ 2. Get connection string from Neon Dashboard                    │
# │ 3. Fill in DATABASE_URL below                                   │
# │ 4. Run: npm run dev                                             │
# └─────────────────────────────────────────────────────────────────┘

# ════════════════════════════════════════════════════════════════════
# REQUIRED CONFIGURATION
# ════════════════════════════════════════════════════════════════════

# Neon Postgres Database Connection
# Get from: https://console.neon.tech/app/projects
# → Select your project → Connection Details → Copy "Connection string"
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ════════════════════════════════════════════════════════════════════
# OPTIONAL CONFIGURATION
# ════════════════════════════════════════════════════════════════════

# Public Site URL (for meta tags and OG images)
# Example: https://yourblog.pages.dev or https://yourdomain.com
PUBLIC_SITE_URL=http://localhost:4321

# GitHub Personal Access Token (for Stats card - higher rate limits)
# Unauthenticated API: 60 requests/hour
# Authenticated API: 5,000 requests/hour
# Get from: https://github.com/settings/tokens → Generate classic token
# Scopes needed: public_repo (read-only)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend Email API (for newsletter subscription feature)
# Get from: https://resend.com/api-keys
# Dev: Use @resend.dev test domain (no domain verification needed)
# Prod: Use your verified domain (e.g., newsletter@yourdomain.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# Resend sender email address (optional, defaults to noreply@resend.dev)
# For production, use your verified domain email
# RESEND_FROM_EMAIL=newsletter@yourdomain.com

# ════════════════════════════════════════════════════════════════════
# ADVANCED CONFIGURATION
# ════════════════════════════════════════════════════════════════════

# MCP Server API Key (for AI assistant article management)
# Generate a secure random key:
#   node -e "console.log('ckb_' + require('crypto').randomBytes(32).toString('hex'))"
#
# The MCP server allows AI assistants (like Claude) to:
# - Create, update, delete articles
# - Manage blog content via structured protocol
# - Provide seamless content management experience
#
# See MCP_SETUP_GUIDE.md for complete documentation
# MCP_API_KEY=ckb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════════════════════
# DEVELOPMENT NOTES
# ════════════════════════════════════════════════════════════════════

# Environment Variable Loading:
# - Local development: .env.local (auto-loaded by Vite)
# - Production: Set in Cloudflare Dashboard → Pages → Settings → Environment Variables
#
# Security:
# - Never commit .env files to git
# - Never share your API keys
# - Rotate keys if exposed
# - Use different keys for dev/prod

# ════════════════════════════════════════════════════════════════════
# TROUBLESHOOTING
# ════════════════════════════════════════════════════════════════════

# Database connection errors?
# - Verify DATABASE_URL format
# - Check SSL mode is enabled (?sslmode=require)
# - Ensure Neon project is not suspended
# - Test connection: psql "$DATABASE_URL"

# GitHub rate limit errors?
# - Add GITHUB_TOKEN for higher limits
# - Check token has correct scopes
# - Verify token hasn't expired

# Build errors?
# - Run: npm ci (clean install)
# - Check Node.js version: node -v (should be 20+)
# - Clear cache: rm -rf .astro dist node_modules

# Need help?
# - Documentation: https://github.com/your-username/cool-blog
# - Issues: https://github.com/your-username/cool-blog/issues
