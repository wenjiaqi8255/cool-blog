---
/**
 * Portfolio Card Component
 * Displays a portfolio article as a card in the bento grid
 */

export interface PortfolioCardProps {
  title: string;
  description?: string;
  image?: string;
  tags?: string[];
  link?: string;
  slug: string;
  date?: Date;
  size?: 'small' | 'medium' | 'large';
  variant?: 'standard' | 'photo';
}

const {
  title,
  description,
  image,
  tags = [],
  link,
  slug,
  date,
  size = 'medium',
  variant = 'standard'
} = Astro.props;

// Format date for display
const formattedDate = date ? new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
}) : '';

// Build CSS classes based on props
const sizeClasses = {
  small: 'card-small',
  medium: 'card-medium',
  large: 'card-large'
};

const variantClasses = variant === 'photo' ? 'card-photo' : 'card-standard';
---

<a
  href={link || `/portfolio/${slug}`}
  class:list={[
    'portfolio-card',
    sizeClasses[size],
    variantClasses
  ]}
  data-slug={slug}
>
  {variant === 'photo' && image && (
    <div class="card-image">
      <img src={image} alt={title} loading="lazy" />
      <div class="image-overlay"></div>
    </div>
  )}

  <div class="card-content">
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.slice(0, 3).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}

    <h3 class="card-title">{title}</h3>

    {description && (
      <p class="card-description">{description}</p>
    )}

    {formattedDate && (
      <time class="card-date" datetime={new Date(date).toISOString()}>
        {formattedDate}
      </time>
    )}
  </div>
</a>

<style>
  .portfolio-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--card-bg, #1a1a2e);
    border: 1px solid var(--card-border, #2d2d44);
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    height: 100%;
    min-height: 280px;
  }

  .portfolio-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.3);
    border-color: var(--accent-primary, #00d4ff);
  }

  .portfolio-card:focus {
    outline: 2px solid var(--accent-primary, #00d4ff);
    outline-offset: 2px;
  }

  .portfolio-card:focus:not(:focus-visible) {
    outline: none;
  }

  /* Size variants */
  .card-small {
    min-height: 200px;
  }

  .card-medium {
    min-height: 280px;
  }

  .card-large {
    min-height: 360px;
  }

  /* Variant: standard */
  .card-standard {
    padding: 24px;
    background: var(--card-bg, #1a1a2e);
  }

  /* Variant: photo */
  .card-photo {
    padding: 0;
  }

  .card-image {
    position: relative;
    width: 100%;
    height: 180px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .portfolio-card:hover .card-image img {
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60%;
    background: linear-gradient(to top, var(--card-bg, #1a1a2e), transparent);
    pointer-events: none;
  }

  .card-photo .card-content {
    padding: 20px;
  }

  /* Content layout */
  .card-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 4px 8px;
    background: var(--accent-primary-dim, rgba(0, 212, 255, 0.15));
    color: var(--accent-primary, #00d4ff);
    border-radius: 4px;
  }

  .card-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary, #f0f0f0);
    line-height: 1.3;
    margin: 0;
  }

  .card-description {
    font-size: 14px;
    color: var(--text-secondary, #a0a0a0);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-date {
    font-size: 12px;
    color: var(--text-muted, #6a6a7a);
    margin-top: auto;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .portfolio-card {
      min-height: 220px;
    }

    .card-small {
      min-height: 160px;
    }

    .card-medium {
      min-height: 220px;
    }

    .card-large {
      min-height: 280px;
    }

    .card-image {
      height: 140px;
    }
  }
</style>