---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { data, slug } = article;
const { title, date, tags, excerpt, coverImage } = data;

// Calculate reading time: words / 200 WPM
// Estimate: average 5 characters per word
const wordCount = article.body ? article.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Format date as YYYY-MM-DD
const formattedDate = date.toISOString().split('T')[0];
---

<article class="article-card">
  <a href={`/articles/${slug}`} class="card-link">
    {coverImage && (
      <div class="cover-image">
        <img src={coverImage} alt={title} />
      </div>
    )}
    <div class="card-content">
      <h3 class="title">{title}</h3>
      {excerpt && <p class="excerpt">{excerpt}</p>}
      <div class="meta">
        <span class="reading-time">{readingTime} min read</span>
        <span class="separator">·</span>
        <time datetime={formattedDate}>{formattedDate}</time>
      </div>
      <div class="tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>
  </a>
</article>

<style>
  .article-card {
    background-color: var(--color-card-light);
    border-radius: 12px;
    min-height: 200px;
    height: 100%;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
    overflow: hidden;
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .cover-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-ink-black);
  }

  .cover-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease-out);
  }

  .article-card:hover .cover-image img {
    transform: scale(1.05);
  }

  .card-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .title {
    font-size: 24px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink-black);
    margin: 0 0 12px 0;
  }

  .excerpt {
    font-size: 14px;
    color: var(--color-ink-gray);
    line-height: 1.5;
    margin: 0 0 16px 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta {
    font-size: 12px;
    color: var(--color-ink-light);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .separator {
    opacity: 0.5;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 20px;
    background: transparent;
    color: var(--color-ink-light);
    border: 1px solid var(--color-ink-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>