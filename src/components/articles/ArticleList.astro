---
import { getCollection } from 'astro:content';
import ArticleCard from './ArticleCard.astro';
import BentoGrid from '../layout/BentoGrid.astro';
import TagFilter from './TagFilter';
import SearchInput from './SearchInput';
import { createSearchIndex, type ArticleSearchItem } from '../lib/search';

// Fetch all non-draft articles, sorted by date (newest first)
const allArticles = await getCollection('articles');
const articles = allArticles
  .filter((article) => !article.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Prepare article data for search index
const searchArticles: ArticleSearchItem[] = articles.map((article) => ({
  id: article.id,
  slug: article.slug,
  title: article.data.title,
  excerpt: article.data.excerpt || '',
  content: article.body || '',
  tags: article.data.tags || [],
  date: article.data.date.toISOString()
}));

const PAGE_SIZE = 6;
---

<div
  class="article-filter-container"
  data-articles={JSON.stringify(searchArticles)}
  data-page-size={PAGE_SIZE}
  data-all-slugs={JSON.stringify(articles.map((a) => a.slug))}
>
  <div class="filter-header">
    <TagFilter
      client:load
      availableTags={['ML', 'Systems', 'Tutorial', 'Project', 'Notes']}
      selectedTags={[]}
      onChange={(tags) => {
        window.dispatchEvent(new CustomEvent('tag-filter-change', { detail: tags }));
      }}
    />
    <SearchInput
      client:load
      onSearch={(query) => {
        window.dispatchEvent(new CustomEvent('search-change', { detail: query }));
      }}
    />
  </div>

  <div class="article-count" id="article-count">加载中...</div>

  <div id="article-list-container">
    <BentoGrid>
      {articles.slice(0, PAGE_SIZE).map((article) => (
        <div class="col-span-1 article-item" data-tags={JSON.stringify(article.data.tags || [])} data-title={article.data.title.toLowerCase()} data-excerpt={(article.data.excerpt || '').toLowerCase()} data-content={(article.body || '').toLowerCase()}>
          <ArticleCard article={article} />
        </div>
      ))}
    </BentoGrid>
  </div>

  <div id="no-results" class="no-results" style="display: none;">
    <p>没有找到匹配的文章</p>
  </div>

  <div id="load-more-container" class="load-more-container">
    {articles.length > PAGE_SIZE && (
      <button id="load-more-btn" type="button" class="load-more-button">
        加载更多
      </button>
    )}
  </div>
</div>

<script>
  import { createSearchIndex, search, type ArticleSearchItem } from '../../lib/search';

  const container = document.querySelector('.article-filter-container') as HTMLElement;
  const articleListContainer = document.getElementById('article-list-container');
  const noResults = document.getElementById('no-results');
  const articleCount = document.getElementById('article-count');
  const loadMoreBtn = document.getElementById('load-more-btn');

  if (!container || !articleListContainer) {
    throw new Error('Required DOM elements not found');
  }

  const articles: ArticleSearchItem[] = JSON.parse(container.dataset.articles || '[]');
  const allSlugs: string[] = JSON.parse(container.dataset.allSlugs || '[]');
  const PAGE_SIZE = parseInt(container.dataset.pageSize || '6', 10);

  // Initialize search index
  createSearchIndex(articles);

  let displayedCount = PAGE_SIZE;
  let selectedTags: string[] = [];
  let searchQuery = '';
  let hasMore = articles.length > PAGE_SIZE;

  // Filter articles based on current filters
  function filterArticles(): ArticleSearchItem[] {
    let filtered = articles;

    // Apply tag filter (OR logic)
    if (selectedTags.length > 0) {
      filtered = filtered.filter((article) =>
        article.tags.some((tag) => selectedTags.includes(tag))
      );
    }

    // Apply search
    if (searchQuery.trim()) {
      const searchResults = search(searchQuery);
      const matchedIds = new Set(searchResults.map((r) => r.item.id));
      filtered = filtered.filter((article) => matchedIds.has(article.id));
    }

    return filtered;
  }

  // Show/hide article elements based on filtered results
  function updateVisibility() {
    const filtered = filterArticles();
    const matchedIds = new Set(filtered.map((a) => a.id));

    // Get all article items in the DOM
    const articleItems = articleListContainer?.querySelectorAll('.article-item');

    if (articleItems) {
      let visibleCount = 0;
      articleItems.forEach((item, index) => {
        const isVisible = matchedIds.has(articles[index]?.id) && visibleCount < displayedCount;
        (item as HTMLElement).style.display = isVisible ? '' : 'none';
        if (isVisible) visibleCount++;
      });
    }

    // Show/hide no results message
    const totalMatches = filtered.length;
    if (totalMatches === 0) {
      noResults.style.display = 'block';
      articleCount.textContent = '0 篇文章';
    } else {
      noResults.style.display = 'none';
      articleCount.textContent = `${totalMatches} 篇文章`;
    }

    // Show/hide load more button
    const loadMoreContainer = document.getElementById('load-more-container');
    if (!loadMoreContainer) return;

    const existingBtn = loadMoreContainer.querySelector('.load-more-button');
    const hasMoreToLoad = totalMatches > displayedCount;

    if (hasMoreToLoad && !existingBtn) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'load-more-button';
      btn.textContent = '加载更多';
      btn.addEventListener('click', () => {
        displayedCount += PAGE_SIZE;
        updateVisibility();
      });
      loadMoreContainer.appendChild(btn);
    } else if (!hasMoreToLoad && existingBtn) {
      existingBtn.remove();
    }
  }

  // Listen for tag filter changes
  window.addEventListener('tag-filter-change', ((event: CustomEvent) => {
    selectedTags = event.detail;
    displayedCount = PAGE_SIZE;
    updateVisibility();
  }) as EventListener);

  // Listen for search changes
  window.addEventListener('search-change', ((event: CustomEvent) => {
    searchQuery = event.detail;
    displayedCount = PAGE_SIZE;
    updateVisibility();
  }) as EventListener);

  // Initial render
  updateVisibility();
</script>

<style>
  .article-filter-container {
    margin-top: 24px;
  }

  .filter-header {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .article-count {
    font-size: 14px;
    color: var(--color-ink-gray);
    margin-bottom: 16px;
  }

  .no-results {
    text-align: center;
    padding: 80px 24px;
    background: var(--color-card-light);
    border-radius: 12px;
    color: var(--color-ink-gray);
    font-size: 16px;
  }

  .load-more-container {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  .load-more-button {
    padding: 12px 24px;
    background: transparent;
    border: 1px solid var(--color-ink);
    color: var(--color-ink);
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s ease;
    border-radius: 8px;
  }

  .load-more-button:hover {
    background: var(--color-ink);
    color: white;
  }

  /* TagFilter styles */
  :global(.tag-filter) {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  :global(.tag-filter-label) {
    font-size: 14px;
    color: var(--color-ink-gray);
  }

  :global(.tag-pills) {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  :global(.tag-pill) {
    padding: 6px 12px;
    border: 1px solid var(--color-ink);
    background: transparent;
    color: var(--color-ink);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s ease;
    border-radius: 16px;
  }

  :global(.tag-pill:hover) {
    background: rgba(17, 17, 17, 0.05);
  }

  :global(.tag-pill.selected) {
    background: var(--color-ink);
    color: white;
  }

  /* SearchInput styles */
  :global(.search-input-wrapper) {
    position: relative;
    display: flex;
    align-items: center;
  }

  :global(.search-input) {
    width: 250px;
    padding: 8px 12px;
    border: 1px solid var(--color-ink);
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s ease;
    border-radius: 8px;
  }

  :global(.search-input:focus) {
    border-color: var(--color-ink);
  }

  :global(.search-clear-button) {
    position: absolute;
    right: 8px;
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
    color: var(--color-ink-gray);
    padding: 4px;
  }

  :global(.search-clear-button:hover) {
    color: var(--color-ink);
  }

  /* Article item for filtering */
  :global(.article-item) {
    transition: opacity 0.2s ease;
  }
</style>