---
import TabNavigation from '../interactive/TabNavigation';
import SubscribeModal from '../interactive/SubscribeModal';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
---

<header class="header">
  <div class="header-content">
    <a href="/" class="brand">
      <span class="brand-text">KERNEL_PANIC</span>
      <span class="brand-divider">/</span>
      <span class="brand-subtitle">ARCHITECTURE & SYSTEMS</span>
    </a>

    <nav class="nav">
      <TabNavigation client:load currentPath={currentPath} />
      <SubscribeModal client:load />
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-canvas-white);
    border-bottom: 1px solid #EEEEEE;
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1600px;
    margin: 0 auto;
    padding: 20px 40px;
    gap: 24px;
  }

  .brand {
    display: flex;
    align-items: baseline;
    gap: 8px;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }

  .brand-text {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-ink-black);
  }

  .brand-divider {
    font-size: 16px;
    color: var(--color-ink-light);
    margin: 0 4px;
  }

  .brand-subtitle {
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--color-ink-gray);
    display: none;
  }

  @media (min-width: 768px) {
    .brand-subtitle {
      display: inline;
    }
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* Mobile: Stack header vertically */
  @media (max-width: 640px) {
    .header-content {
      flex-direction: column;
      align-items: flex-start;
      padding: 16px;
      gap: 16px;
    }

    .nav {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
