---
import { pages, type PageKey } from '../../config/content';

interface Props {
  currentPage?: PageKey;
}

const { currentPage = 'home' } = Astro.props;
const pageConfig = pages[currentPage];
const currentYear = new Date().getFullYear();

// Social links configuration
const socialLinks = [
  {
    id: 'github',
    name: 'GitHub',
    url: 'https://github.com/wenjiaqi8255',
    icon: 'github'
  },
  {
    id: 'website',
    name: 'Website',
    url: 'https://blog.wenjiaqi.top/',
    icon: 'website'
  },
  {
    id: 'xiaohongshu',
    name: '小红书',
    url: 'https://www.xiaohongshu.com/user/profile/56628602e00dd83ffa6ce02e',
    icon: 'xiaohongshu'
  }
];

const creditName = 'WEN';
const creditTagline = 'Building Something Fun';
const creditLabel = 'Crafted with ♥ by';
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-left">
      <span class="brand">{pageConfig.footerBrand || 'KERNEL_PANIC'}</span>
      <span class="copyright">© {currentYear} {pageConfig.footerBrand || 'KERNEL PANIC'}</span>
    </div>

    <div class="footer-right">
      <div class="credit-section">
        <span class="credit-label">{creditLabel}</span>
        <a href={socialLinks[0].url} target="_blank" rel="noopener noreferrer" class="credit-name">
          {creditName}
        </a>
        <span class="credit-tagline">{creditTagline}</span>
        <div class="social-links">
          {socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label={link.name}
            >
              {link.icon === 'github' ? (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                  <path d="M9 18c-4.51 2-5-2-7-2" />
                </svg>
              ) : link.icon === 'website' ? (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10" />
                  <line x1="2" y1="12" x2="22" y2="12" />
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                  <circle cx="12" cy="12" r="4"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 48px;
    padding: 32px 40px;
    border-top: 1px solid #EEEEEE;
  }

  .footer-content {
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .brand {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-ink-black);
    letter-spacing: -0.02em;
  }

  .copyright {
    font-size: 10px;
    color: var(--color-ink-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-right {
    display: flex;
    align-items: center;
  }

  .credit-section {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .credit-label {
    font-size: 11px;
    color: var(--color-ink-light);
  }

  .credit-name {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-ink-black);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .credit-name:hover {
    opacity: 0.7;
  }

  .credit-tagline {
    font-size: 11px;
    color: var(--color-ink-light);
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-left: 8px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: var(--color-ink-light);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .social-link:hover {
    color: var(--color-ink-black);
    transform: translateY(-2px);
  }

  .social-link svg {
    width: 16px;
    height: 16px;
  }

  @media (max-width: 640px) {
    .footer {
      padding: 24px 16px;
    }

    .footer-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .credit-section {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .social-links {
      margin-left: 0;
    }
  }
</style>
