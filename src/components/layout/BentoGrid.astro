---
import { portfolioCards, type CardConfig } from '../../config/cards';
import ImageCard from '../cards/ImageCard.astro';
import TextCard from '../cards/TextCard.astro';
import TerminalCard from '../cards/TerminalCard.astro';
import StatsCard from '../cards/StatsCard.astro';

interface Props {
  cards?: CardConfig[];
}

const { cards = portfolioCards } = Astro.props;
const hasChildren = Boolean(Astro.slots.has('default'));

// Map card types to components
const cardComponents = {
  image: ImageCard,
  text: TextCard,
  terminal: TerminalCard,
  stats: StatsCard
};
---

<div class="bento-grid">
  {hasChildren ? (
    <slot />
  ) : (
    cards.map((card) => {
      const Component = cardComponents[card.type];

      return (
        <div
          class:list={[
            'bento-card',
            `col-span-${card.span}`,
            card.row === 2 && 'row-span-2'
          ]}
          data-card-id={card.id}
          data-card-type={card.type}
        >
          <Component {...card.props} variant={card.variant} />
        </div>
      );
    })
  )}
</div>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-card-gap);
    max-width: var(--layout-max-width);
    margin: 0 auto;
    width: 100%;
    grid-auto-rows: minmax(var(--layout-min-card-height), auto);
  }

  /* Column span utilities */
  .col-span-1 {
    grid-column: span 1;
  }

  .col-span-2 {
    grid-column: span 2;
  }

  .col-span-4 {
    grid-column: span 4;
  }

  .row-span-2 {
    grid-row: span 2;
  }

  /* Tablet: 2 columns */
  @media (max-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Full-width cards on tablet */
    .col-span-4 {
      grid-column: span 2;
    }
  }

  /* Mobile: 1 column */
  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    /* All cards full-width on mobile */
    .col-span-1,
    .col-span-2,
    .col-span-4 {
      grid-column: span 1;
    }

    .row-span-2 {
      grid-row: span 1;
    }
  }

  /* Card container */
  .bento-card {
    min-height: 320px;
  }
</style>
