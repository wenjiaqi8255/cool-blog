---
interface Props {
  title?: string;
  commands?: string[];
  link?: string;
  variant?: 'light' | 'dark';
  metaTag?: string;
  body?: string;
}

const { title, commands = [], link = '#', variant = 'dark', metaTag, body } = Astro.props;
---

<div class:list={['card', variant]}>
  <a href={link} class="card-link">
    <span class="arrow-icon" aria-hidden="true">↗</span>
    {metaTag && <span class="meta-tag">{metaTag}</span>}
    {title && <h3 class="headline">{title}</h3>}
    {body && <p class="copy">{body}</p>}
    {commands.length > 0 && (
      <div class="terminal-block">
        {commands.map((cmd, i) => (
          <div class="terminal-line">
            {i === commands.length - 1 ? (
              <>
                <span class="prompt">{cmd}</span><span class="cursor"></span>
              </>
            ) : (
              <span class="prompt">{cmd}</span>
            )}
          </div>
        ))}
      </div>
    )}
  </a>
</div>

<style>
  .card {
    background-color: var(--color-card-light);
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
    transition: background-color 0.4s var(--ease-out);
    text-decoration: none;
    color: var(--color-ink-black);
    min-height: 320px;
    height: 100%;
  }

  .card:hover {
    background-color: var(--color-card-hover);
  }

  .card:hover .arrow-icon {
    transform: translate(4px, -4px);
  }

  .card.dark {
    background-color: var(--color-ink-black);
    color: var(--color-canvas-white);
  }

  .card.dark:hover {
    background-color: #000;
  }

  .card.dark .meta-tag,
  .card.dark .copy {
    color: #888;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .arrow-icon {
    position: absolute;
    top: 24px;
    right: 24px;
    font-size: 14px;
    transition: transform 0.3s var(--ease-out);
  }

  .meta-tag {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-light);
    margin-bottom: 16px;
    display: block;
  }

  .headline {
    font-size: 28px;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    max-width: 90%;
  }

  .copy {
    font-size: 13px;
    color: var(--color-ink-gray);
    line-height: 1.5;
    max-width: 300px;
    margin: 0 0 20px 0;
  }

  .terminal-block {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: #333;
    margin-top: auto;
    border-top: 1px solid #E5E5E5;
    padding-top: 20px;
    width: 100%;
  }

  .card.dark .terminal-block {
    color: #aaa;
    border-top: 1px solid #333;
  }

  .terminal-line {
    margin-bottom: 4px;
  }

  .prompt::before {
    content: "➜ ";
    color: var(--color-ink-light);
  }

  .cursor {
    display: inline-block;
    width: 6px;
    height: 14px;
    background-color: var(--color-ink-black);
    animation: blink 1s step-end infinite;
    vertical-align: middle;
    margin-left: 4px;
  }

  .card.dark .cursor {
    background-color: #fff;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }
</style>
