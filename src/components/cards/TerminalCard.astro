---
interface Props {
  title?: string;
  commands: string[];
  link?: string;
}

const { title, commands, link = '#' } = Astro.props;
---

<div class="terminal-card">
  <a href={link} class="card-link">
    {title && <h3 class="title">{title}</h3>}
    <div class="terminal">
      <div class="terminal-header">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>
      <pre class="terminal-body"><code>{commands.map(cmd => `> ${cmd}`).join('\n')}<span class="cursor">▊</span></code></pre>
    </div>
  </a>
</div>

<style>
  .terminal-card {
    background: var(--color-dark-card-bg);
    border-radius: 8px;
    overflow: hidden;
    height: 100%;
    min-height: 320px;
    transition: background-color 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .terminal-card:hover {
    background: var(--color-dark-card-hover);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    padding: 24px;
  }

  .title {
    font-size: 16px;
    font-weight: 300;
    letter-spacing: -0.02em;
    margin: 0 0 16px 0;
    color: #FFFFFF;
  }

  .terminal {
    flex: 1;
    background: #000000;
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .terminal-header {
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    background: #1a1a1a;
    border-bottom: 1px solid #333333;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #FF5F56; }
  .dot.yellow { background: #FFBD2E; }
  .dot.green { background: #27C93F; }

  .terminal-body {
    flex: 1;
    margin: 0;
    padding: 16px;
    font-family: var(--font-family-mono);
    font-size: 14px;
    font-weight: 300;
    color: #F0F0F0;
    white-space: pre-wrap;
    word-break: break-word;
    line-height: 1.6;
    overflow: auto;
  }

  .cursor {
    display: inline-block;
    animation: blink 1s step-end infinite;
    color: #FFFFFF;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
</style>
