---
interface Props {
  image: string;
  title?: string;
  subtitle?: string;
  metaTag?: string;
  link?: string;
  variant?: 'light' | 'dark';
}

const { image, title, subtitle, metaTag, link = '#', variant = 'light' } = Astro.props;
---

<div class:list={['card', variant]}>
  <a href={link} class="card-link">
    <img src={image} alt={title || 'Card image'} class="card-image" loading="lazy" decoding="async" />
    <div class="content-overlay">
      {metaTag && <span class="meta-tag">{metaTag}</span>}
      {title && (
        <div class="title-wrapper">
          <h3 class="headline">{title}</h3>
          <span class="arrow-icon" aria-hidden="true">↗</span>
        </div>
      )}
    </div>
  </a>
</div>

<style>
  .card {
    position: relative;
    overflow: hidden;
    height: 100%;
    min-height: 320px;
    background-color: var(--color-card-light);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    filter: grayscale(100%) contrast(1.1);
    transition: filter 0.4s ease, transform 0.6s ease;
    z-index: 0;
  }

  .card:hover .card-image {
    filter: grayscale(0%) contrast(1);
    transform: scale(1.02);
  }

  .content-overlay {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 32px;
    color: white;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }

  .meta-tag {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.8);
    margin-bottom: 16px;
    display: block;
  }

  .title-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .headline {
    font-size: 28px;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 90%;
  }

  .arrow-icon {
    font-size: 14px;
    margin-top: 16px;
    transition: transform 0.3s var(--ease-out);
  }

  .card:hover .arrow-icon {
    transform: translate(4px, -4px);
  }
</style>
