---
interface Props {
  image: string;
  title: string;
  subtitle?: string;
  link?: string;
  variant?: 'light' | 'dark';
}

const { image, title, subtitle, link = '#', variant = 'light' } = Astro.props;
---

<div class:list={['image-card', variant]}>
  <a href={link} class="card-link">
    <div class="image-wrapper">
      <img src={image} alt={title} loading="lazy" decoding="async" />
    </div>
    <div class="content">
      <div class="text">
        <h3 class="title">{title}</h3>
        {subtitle && <p class="subtitle">{subtitle}</p>}
      </div>
      <span class="arrow" aria-hidden="true">↗</span>
    </div>
  </a>
</div>

<style>
  .image-card {
    background: var(--color-card-light);
    border-radius: 8px;
    overflow: hidden;
    height: 100%;
    min-height: 320px;
    transition: background-color 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .image-card:hover {
    background: var(--color-card-hover);
  }

  .image-card.dark {
    background: var(--color-dark-card-bg);
  }

  .image-card.dark:hover {
    background: var(--color-dark-card-hover);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .image-wrapper {
    flex: 1;
    overflow: hidden;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition:
      filter 400ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .image-card:hover .image-wrapper img {
    filter: grayscale(0%);
    transform: scale(1.02);
  }

  .content {
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
  }

  .text {
    flex: 1;
    min-width: 0;
  }

  .title {
    font-size: 20px;
    font-weight: 300;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-ink-black);
  }

  .image-card.dark .title {
    color: #FFFFFF;
  }

  .subtitle {
    font-size: 14px;
    color: var(--color-ink-gray);
    margin: 4px 0 0 0;
  }

  .image-card.dark .subtitle {
    color: #999999;
  }

  .arrow {
    font-size: 16px;
    color: var(--color-ink-gray);
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }

  .image-card.dark .arrow {
    color: #999999;
  }

  .image-card:hover .arrow {
    transform: translate(4px, -4px);
  }
</style>
