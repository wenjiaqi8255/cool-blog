---
interface Props {
  image?: string;
  title?: string;
  subtitle?: string;
  metaTag?: string;
  link?: string;
  variant?: 'light' | 'dark';
  body?: string;
}

const { image, title, subtitle, metaTag, link = '#', variant = 'light', body } = Astro.props;
---

<!-- Image card: shows image with overlay content -->
{image && (
  <div class:list={['card', variant]}>
    <a href={link} class="card-link">
      <img src={image} alt={title || 'Card image'} class="card-image" loading="lazy" decoding="async" />
      <div class="content-overlay">
        {metaTag && <span class="meta-tag">{metaTag}</span>}
        {title && (
          <div class="title-wrapper">
            <h3 class="headline">{title}</h3>
            <span class="arrow-icon" aria-hidden="true">↗</span>
          </div>
        )}
      </div>
    </a>
  </div>
)}

<!-- Text card fallback: shown when no image -->
{!image && (
  <div class:list={['card', 'text-card', variant]}>
    <a href={link} class="card-link">
      <span class="arrow-icon" aria-hidden="true">↗</span>
      {metaTag && <span class="meta-tag">{metaTag}</span>}
      <h3 class="headline">{title}</h3>
      {body && <p class="copy">{body}</p>}
    </a>
  </div>
)}

<style>
  .card {
    position: relative;
    overflow: hidden;
    height: 100%;
    min-height: 320px;
    background-color: var(--color-card-light);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    filter: grayscale(100%) contrast(1.1);
    transition: filter 0.4s ease, transform 0.6s ease;
    z-index: 0;
  }

  .card:hover .card-image {
    filter: grayscale(0%) contrast(1);
    transform: scale(1.02);
  }

  .content-overlay {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 32px;
    color: white;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }

  .meta-tag {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.8);
    margin-bottom: 16px;
    display: block;
  }

  .title-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .headline {
    font-size: 28px;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 90%;
  }

  .arrow-icon {
    font-size: 14px;
    margin-top: 16px;
    transition: transform 0.3s var(--ease-out);
  }

  .card:hover .arrow-icon {
    transform: translate(4px, -4px);
  }

  /* Text card fallback styles */
  .text-card {
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .text-card .arrow-icon {
    position: absolute;
    top: 24px;
    right: 24px;
  }

  .text-card .meta-tag {
    color: var(--color-ink-light);
  }

  .text-card .copy {
    font-size: 13px;
    color: var(--color-ink-gray);
    line-height: 1.5;
    max-width: 300px;
    margin: 0;
  }

  .text-card.dark {
    background-color: var(--color-ink-black);
    color: var(--color-canvas-white);
  }

  .text-card.dark .meta-tag,
  .text-card.dark .copy {
    color: #888;
  }
</style>
