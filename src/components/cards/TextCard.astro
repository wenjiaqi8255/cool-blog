---
interface Props {
  title: string;
  body?: string;
  link?: string;
  variant?: 'light' | 'dark';
  metaTag?: string;
}

const { title, body, link = '#', variant = 'light', metaTag } = Astro.props;
---

<div class:list={['card', variant]}>
  <a href={link} class="card-link">
    <span class="arrow-icon" aria-hidden="true">↗</span>
    {metaTag && <span class="meta-tag">{metaTag}</span>}
    <h3 class="headline">{title}</h3>
    {body && <p class="copy">{body}</p>}
  </a>
</div>

<style>
  .card {
    background-color: var(--color-card-light);
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
    transition: background-color 0.4s var(--ease-out);
    text-decoration: none;
    color: var(--color-ink-black);
    min-height: 320px;
    height: 100%;
  }

  .card:hover {
    background-color: var(--color-card-hover);
  }

  .card:hover .arrow-icon {
    transform: translate(4px, -4px);
  }

  .card.dark {
    background-color: var(--color-ink-black);
    color: var(--color-canvas-white);
  }

  .card.dark:hover {
    background-color: #000;
  }

  .card.dark .meta-tag,
  .card.dark .copy {
    color: #888;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .arrow-icon {
    position: absolute;
    top: 24px;
    right: 24px;
    font-size: 14px;
    transition: transform 0.3s var(--ease-out);
  }

  .meta-tag {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-light);
    margin-bottom: 16px;
    display: block;
  }

  .headline {
    font-size: 28px;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    max-width: 90%;
  }

  .copy {
    font-size: 13px;
    color: var(--color-ink-gray);
    line-height: 1.5;
    max-width: 300px;
    margin: 0;
  }
</style>
