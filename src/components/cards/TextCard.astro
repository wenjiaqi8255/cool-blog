---
interface Props {
  title: string;
  body?: string;
  link?: string;
  variant?: 'light' | 'dark';
  metaTag?: string;
  // For modal trigger - when true, clicking opens modal instead of navigating
  isModalTrigger?: boolean;
}

const { title, body, link = '#', variant = 'light', metaTag, isModalTrigger = false } = Astro.props;

// Determine if this should be a modal trigger
const isModal = isModalTrigger || link === '#';
---

<div class:list={['card', variant]}>
  {isModal ? (
    <button type="button" class="card-trigger" aria-label={`View ${title}`}>
      <span class="arrow-icon" aria-hidden="true">↗</span>
      {metaTag && <span class="meta-tag">{metaTag}</span>}
      <h3 class="headline">{title}</h3>
      {body && <p class="copy">{body}</p>}
    </button>
  ) : (
    <a href={link} class="card-link">
      <span class="arrow-icon" aria-hidden="true">↗</span>
      {metaTag && <span class="meta-tag">{metaTag}</span>}
      <h3 class="headline">{title}</h3>
      {body && <p class="copy">{body}</p>}
    </a>
  )}
</div>

<style>
  .card {
    background-color: var(--color-card-light);
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
    transition: background-color 0.4s var(--ease-out);
    text-decoration: none;
    color: var(--color-ink-black);
    min-height: 320px;
    height: 100%;
  }

  .card:hover {
    background-color: var(--color-card-hover);
  }

  .card:hover .arrow-icon {
    transform: translate(4px, -4px);
  }

  .card.dark {
    background-color: var(--color-ink-black);
    color: var(--color-canvas-white);
  }

  .card.dark:hover {
    background-color: #000;
  }

  .card.dark .meta-tag,
  .card.dark .copy {
    color: #888;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .arrow-icon {
    position: absolute;
    top: 24px;
    right: 24px;
    font-size: 14px;
    transition: transform 0.3s var(--ease-out);
  }

  .meta-tag {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-light);
    margin-bottom: 16px;
    display: block;
  }

  .headline {
    font-size: 28px;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    max-width: 90%;
  }

  .copy {
    font-size: 13px;
    color: var(--color-ink-gray);
    line-height: 1.5;
    max-width: 300px;
    margin: 0;
  }

  /* Button trigger styles */
  .card-trigger {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
    text-align: left;
    font: inherit;
    color: inherit;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
    min-height: 320px;
  }

  .card-trigger:hover .arrow-icon {
    transform: translate(4px, -4px);
  }
</style>
