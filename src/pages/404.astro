---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const currentPath = Astro.url.pathname;
---

<BaseLayout
  title="KERNEL_PANIC / 404 Not Found"
  description="Page not found"
  type="website"
>
  <div class="layout-wrapper">
    <Header currentPath={currentPath} />
    <main class="main-content">
      <div class="not-found">
        <h1 class="not-found-title">Article not found</h1>
        <p class="not-found-body">The article may have been removed or the URL is incorrect.</p>
        <a href="/articles" class="back-link">Back to Articles</a>
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>

<style>
  .layout-wrapper {
    max-width: 1600px;
    margin: 0 auto;
    padding: 40px;
  }

  .main-content {
    margin-top: 24px;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .not-found {
    text-align: center;
    padding: 80px 24px;
  }

  .not-found-title {
    font-size: 48px;
    font-weight: 200;
    letter-spacing: -0.04em;
    color: var(--color-ink-black);
    margin: 0 0 16px 0;
  }

  .not-found-body {
    font-size: 18px;
    color: var(--color-ink-gray);
    margin: 0 0 32px 0;
  }

  .back-link {
    display: inline-block;
    padding: 12px 24px;
    background: transparent;
    border: 1px solid var(--color-ink);
    color: var(--color-ink);
    font-size: 14px;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .back-link:hover {
    background: var(--color-ink);
    color: white;
  }

  @media (max-width: 768px) {
    .layout-wrapper {
      padding: 16px;
    }

    .not-found-title {
      font-size: 32px;
    }

    .not-found-body {
      font-size: 16px;
    }
  }
</style>