---
import { pages } from '../../config/content';
import { listPublishedArticles } from '../../lib/articles';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import ArticleCard from '../../components/articles/ArticleCard.astro';
import BentoGrid from '../../components/layout/BentoGrid.astro';

const currentPath = Astro.url.pathname;

// Fetch published articles from database
const articles = await listPublishedArticles();
const articleCount = articles.length;
---

<BaseLayout
  title={`${pages.articles.title} | Articles`}
  description={pages.articles.description}
  type="website"
>
  <div class="layout-wrapper">
    <Header currentPath={currentPath} />
    <main class="main-content">
      <div class="page-header">
        <h1 class="page-title">Articles</h1>
        <p class="page-description">
          {pages.articles.description}
        </p>
      </div>

      {articleCount === 0 ? (
        <div class="empty-state">
          <h2>No articles yet</h2>
          <p>Articles will appear here once published.</p>
        </div>
      ) : (
        <div class="article-count">{articleCount} articles</div>
      )}

      {articleCount > 0 && (
        <BentoGrid>
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </BentoGrid>
      )}
    </main>
    <Footer />
  </div>
</BaseLayout>

<style>
  .layout-wrapper {
    max-width: 1600px;
    margin: 0 auto;
    padding: 40px;
  }

  .main-content {
    margin-top: 24px;
    min-height: 60vh;
  }

  .page-header {
    margin-bottom: 24px;
  }

  .page-title {
    font-size: 48px;
    font-weight: 200;
    letter-spacing: -0.04em;
    color: var(--color-ink-black);
    margin: 0 0 16px 0;
  }

  .page-description {
    font-size: 18px;
    color: var(--color-ink-gray);
    margin: 0;
    max-width: 600px;
  }

  .article-count {
    font-size: 14px;
    color: var(--color-ink-gray);
    margin-bottom: 16px;
  }

  .empty-state {
    text-align: center;
    padding: 80px 24px;
    background: var(--color-card-light);
    border-radius: 12px;
    color: var(--color-ink-gray);
  }

  .empty-state h2 {
    font-size: 24px;
    font-weight: 400;
    margin: 0 0 8px 0;
    color: var(--color-ink-black);
  }

  .empty-state p {
    font-size: 16px;
    margin: 0;
  }

  @media (max-width: 768px) {
    .layout-wrapper {
      padding: 16px;
    }

    .page-title {
      font-size: 32px;
    }

    .page-description {
      font-size: 16px;
    }
  }
</style>