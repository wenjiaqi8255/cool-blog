---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import ArticleList from '../../components/articles/ArticleList.astro';

const currentPath = Astro.url.pathname;

// Fetch article count for metadata
const { getCollection } = await import('astro:content');
const allArticles = await getCollection('articles');
const articleCount = allArticles.filter(a => !a.data.draft).length;
---

<BaseLayout
  title="Articles — KERNEL_PANIC"
  description={`${articleCount} technical articles on machine learning, systems engineering, and software craftsmanship`}
>
  <div class="layout-wrapper">
    <Header currentPath={currentPath} />
    <main class="main-content">
      <div class="page-header">
        <h1 class="page-title">Articles</h1>
        <p class="page-description">
          Deep dives into machine learning, distributed systems, and the craft of building robust software.
        </p>
      </div>

      <ArticleList />
    </main>
    <Footer />
  </div>
</BaseLayout>

<style>
  .layout-wrapper {
    max-width: 1600px;
    margin: 0 auto;
    padding: 40px;
  }

  .main-content {
    margin-top: 24px;
    min-height: 60vh;
  }

  .page-header {
    margin-bottom: 24px;
  }

  .page-title {
    font-size: 48px;
    font-weight: 200;
    letter-spacing: -0.04em;
    color: var(--color-ink-black);
    margin: 0 0 16px 0;
  }

  .page-description {
    font-size: 18px;
    color: var(--color-ink-gray);
    margin: 0;
    max-width: 600px;
  }

  @media (max-width: 768px) {
    .layout-wrapper {
      padding: 16px;
    }

    .page-title {
      font-size: 32px;
    }

    .page-description {
      font-size: 16px;
    }
  }
</style>