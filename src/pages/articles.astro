---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const currentPath = Astro.url.pathname;
---

<BaseLayout
  title="Articles — KERNEL_PANIC"
  description="Technical articles on machine learning, systems engineering, and software craftsmanship"
>
  <div class="layout-wrapper">
    <Header currentPath={currentPath} />
    <main class="main-content">
      <h1 class="page-title">Articles</h1>
      <p class="page-description">
        Deep dives into machine learning, distributed systems, and the craft of building robust software.
      </p>

      <div class="placeholder-state">
        <div class="placeholder-icon">📝</div>
        <h2 class="placeholder-title">Articles Coming Soon</h2>
        <p class="placeholder-text">
          Phase 2 will populate this page with technical articles and tutorials.
        </p>
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>

<style>
  .layout-wrapper {
    max-width: 1600px;
    margin: 0 auto;
    padding: 40px;
  }

  .main-content {
    margin-top: 24px;
    min-height: 60vh;
  }

  .page-title {
    font-size: 48px;
    font-weight: 200;
    letter-spacing: -0.04em;
    color: var(--color-ink-black);
    margin: 0 0 16px 0;
  }

  .page-description {
    font-size: 18px;
    color: var(--color-ink-gray);
    margin: 0 0 48px 0;
    max-width: 600px;
  }

  .placeholder-state {
    text-align: center;
    padding: 80px 24px;
    background: var(--color-card-light);
    border-radius: 12px;
  }

  .placeholder-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .placeholder-title {
    font-size: 24px;
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--color-ink-black);
    margin: 0 0 8px 0;
  }

  .placeholder-text {
    font-size: 14px;
    color: var(--color-ink-gray);
    margin: 0;
  }

  @media (max-width: 768px) {
    .layout-wrapper {
      padding: 16px;
    }

    .page-title {
      font-size: 32px;
    }

    .page-description {
      font-size: 16px;
    }
  }
</style>
