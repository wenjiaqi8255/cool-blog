---
import { pages } from '../config/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import BentoGrid from '../components/layout/BentoGrid.astro';
import Footer from '../components/layout/Footer.astro';
import PortfolioModal from '../components/interactive/PortfolioModal';
import LoadingAnimation from '../components/animations/LoadingAnimation.astro';
import { listPortfolioArticlesCached, type Article } from '../lib/articles';
import { mapArticlesToCards, portfolioConfig } from '../config/portfolio';
import type { CardConfig } from '../config/cards';
import { getVisitorCountCached, isRedisConfigured } from '../lib/visitor-counter';

const currentPath = Astro.url.pathname;

// Fetch portfolio articles with caching
let portfolioArticles: Article[] = [];
let portfolioCards: CardConfig[] = [];

try {
  portfolioArticles = await listPortfolioArticlesCached();
  portfolioCards = mapArticlesToCards(portfolioArticles, portfolioConfig);
} catch (error) {
  console.error('Failed to load portfolio articles:', error);
  // Keep empty arrays to show loading animation
}

// Fetch visitor count for stats card
const visitorCount = isRedisConfigured()
  ? await getVisitorCountCached()
  : null;

// Add visitor stats card to the grid
const cards: CardConfig[] = [
  ...portfolioCards,
  {
    id: 'visitor-stats',
    type: 'stats',
    span: 1,
    props: {
      label: 'Repo Activity',
      title: 'Visitor Count',
      value: visitorCount !== null ? visitorCount.toLocaleString() : '---'
    }
  }
];

// Determine if we should show animation (no articles)
const showAnimation = cards.length === 1; // Only stats card
---

<BaseLayout
  title={`${pages.home.title} | Home`}
  description={pages.home.description}
  type="website"
>
  <div class="layout-wrapper">
    <Header currentPath={currentPath} />

    <main class="bento-grid-container">
      {showAnimation ? (
        <LoadingAnimation />
      ) : (
        <BentoGrid cards={cards} />
      )}
    </main>

    <Footer />
  </div>

  <!-- Portfolio Modal: Client-side component for modal interactivity -->
  <PortfolioModal
    client:load
    articles={portfolioArticles.map((a) => ({
      ...a,
      date: a.date instanceof Date ? a.date.toISOString() : a.date
    }))}
  />

  <script>
    // Client-side interactivity for portfolio cards in BentoGrid
    document.querySelectorAll('.bento-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        // Prevent event from bubbling up from buttons inside cards
        if (e.target.closest('button.card-trigger')) {
          const cardId = card.getAttribute('data-card-id');
          if (cardId) {
            e.preventDefault();
            window.dispatchEvent(new CustomEvent('open-portfolio-modal', {
              detail: { slug: cardId }
            }));
          }
          return;
        }

        const link = card.querySelector('a');
        if (link) {
          // If card has a link, let it navigate naturally
          return;
        }

        // Otherwise, check if it's a portfolio card
        const cardId = card.getAttribute('data-card-id');
        if (cardId) {
          window.dispatchEvent(new CustomEvent('open-portfolio-modal', {
            detail: { slug: cardId }
          }));
        }
      });
    });

    // Track visitor (only on first visit per session)
    if (!sessionStorage.getItem('visited')) {
      fetch('/api/track-visit', { method: 'POST' })
        .then(() => sessionStorage.setItem('visited', 'true'))
        .catch((err) => console.error('Failed to track visit:', err));
    }
  </script>
</BaseLayout>

<style>
  .layout-wrapper {
    max-width: 1600px;
    margin: 0 auto;
    padding: 40px;
  }

  .bento-grid-container {
    margin-top: 40px;
  }

  @media (max-width: 768px) {
    .layout-wrapper {
      padding: 16px;
    }

    .bento-grid-container {
      margin-top: 24px;
    }
  }
</style>